-- ─────────────────────────────────────────────
-- 8. TASKS — 2 tareas por reparación
-- ─────────────────────────────────────────────
INSERT INTO public.tasks (id_repair, id_user, name, description, status, estimated_time, cost)
SELECT r.id_repair, mec.id_user, t.name, t.description, t.status, t.estimated_time, t.cost
FROM (
    VALUES
    -- Madrid activas
    ('MAD-0001', 'mec1.madrid@taller.com', 'Inspección circuito de frenos',     'Revisión visual y de presión de todo el circuito',      'IN_PROGRESS', 60,  0.00),
    ('MAD-0001', 'mec2.madrid@taller.com', 'Cambio líquido de frenos',          'Vaciado y rellenado con líquido DOT4',                  'PENDING',     30,  0.00),
    ('MAD-0002', 'mec1.madrid@taller.com', 'Desmontaje suspensión delantera',   'Retirar ruedas y conjunto de suspensión',               'IN_PROGRESS', 90,  0.00),
    ('MAD-0002', 'mec2.madrid@taller.com', 'Instalación amortiguadores nuevos', 'Montar amortiguadores Bilstein y apretar a par',        'PENDING',     60,  0.00),
    -- Madrid completadas
    ('MAD-0003', 'mec1.madrid@taller.com', 'Cambio de aceite 5W30',             'Vaciado, cambio filtro y llenado 4.5L aceite',          'DONE',        30,  90.00),
    ('MAD-0003', 'mec2.madrid@taller.com', 'Sustitución filtro aire y bujías',  'Cambio filtro K&N y 4 bujías NGK',                     'DONE',        20,  90.00),
    ('MAD-0004', 'mec1.madrid@taller.com', 'Cambio pastillas delanteras',       'Sustitución pastillas Brembo eje delantero',            'DONE',        45, 160.00),
    ('MAD-0004', 'mec2.madrid@taller.com', 'Cambio discos traseros',            'Sustitución discos ventilados eje trasero',             'DONE',        60, 160.00),
    -- Barcelona activas
    ('BCN-0001', 'mec1.bcn@taller.com',    'Lectura de errores centralita',     'Conexión OBD2 y volcado de códigos de error',           'IN_PROGRESS', 45,  0.00),
    ('BCN-0001', 'mec2.bcn@taller.com',    'Actualización firmware ECU',        'Flash de nueva versión de software de motor',           'PENDING',     90,  0.00),
    ('BCN-0002', 'mec1.bcn@taller.com',    'Inspección turbocompresor',         'Desmontaje y medición de holguras del turbo',           'IN_PROGRESS', 120, 0.00),
    ('BCN-0002', 'mec2.bcn@taller.com',    'Limpieza sistema de admisión',      'Limpieza con spray del cuerpo de mariposa y EGR',       'PENDING',     40,  0.00),
    -- Barcelona completadas
    ('BCN-0003', 'mec1.bcn@taller.com',    'Revisión general 50k',              'Comprobación de 40 puntos según checklist oficial',     'DONE',       180, 225.00),
    ('BCN-0003', 'mec2.bcn@taller.com',    'Cambio fluidos revisión',           'Aceite, refrigerante, líquido dirección',               'DONE',        60, 225.00),
    ('BCN-0004', 'mec1.bcn@taller.com',    'Cambio correa distribución',        'Sustitución correa Gates y tensor',                     'DONE',       150, 290.00),
    ('BCN-0004', 'mec2.bcn@taller.com',    'Cambio bomba de agua',              'Sustitución bomba y sellado con junta nueva',           'DONE',        90, 290.00),
    -- Sevilla activas
    ('SEV-0001', 'mec1.sevilla@taller.com','Diagnóstico caja de cambios',       'Lectura de errores TCU y prueba en rodillos',           'IN_PROGRESS', 60,  0.00),
    ('SEV-0001', 'mec2.sevilla@taller.com','Pedido de solenoide de cambio',     'Localización y pedido de pieza al distribuidor',        'PENDING',     15,  0.00),
    ('SEV-0002', 'mec1.sevilla@taller.com','Localización sensor O2',            'Identificar banco y posición del sensor defectuoso',    'IN_PROGRESS', 30,  0.00),
    ('SEV-0002', 'mec2.sevilla@taller.com','Sustitución sensor de oxígeno',     'Cambio sensor Bosch LSU 4.9 y reset de adaptaciones',   'PENDING',     45,  0.00),
    -- Sevilla completadas
    ('SEV-0003', 'mec1.sevilla@taller.com','Cambio batería 70Ah',               'Sustitución batería Varta y registro en BMS',           'DONE',        30, 105.00),
    ('SEV-0003', 'mec2.sevilla@taller.com','Revisión alternador',               'Medición de tensión de carga y prueba de diodos',       'DONE',        45, 105.00),
    ('SEV-0004', 'mec1.sevilla@taller.com','Montaje neumáticos Michelin',       'Desmontaje, montaje y equilibrado 4 ruedas',            'DONE',        60, 195.00),
    ('SEV-0004', 'mec2.sevilla@taller.com','Alineación de dirección',           'Alineación en 4 ruedas con banco láser',                'DONE',        45, 195.00)
) AS t(plate, mec_email, name, description, status, estimated_time, cost)
JOIN public.cars    c   ON c.plate = t.plate
JOIN public.repairs r   ON r.id_car = c.id_car
JOIN public.users   mec ON mec.email = t.mec_email;

-- ─────────────────────────────────────────────
-- 9. INVOICES — solo para reparaciones COMPLETED
-- ─────────────────────────────────────────────
INSERT INTO public.invoices (id_repair, total, issued_at)
SELECT r.id_repair, r.total_cost, NOW()
FROM public.repairs r
WHERE r.status = 'COMPLETED';

-- ─────────────────────────────────────────────
-- 10. RESERVATIONS — 1 por reparación activa
-- ─────────────────────────────────────────────
INSERT INTO public.reservations (id_user, id_car, id_taller, date, duration, status, votes, created_at)
SELECT
    c.id_user,
    r.id_car,
    u.id_taller,
    NOW() + INTERVAL '2 days',
    60,
    'OPEN',
    0,
    NOW()
FROM public.repairs   r
JOIN public.cars      c ON c.id_car   = r.id_car
JOIN public.users     u ON u.id_user  = c.id_user
WHERE r.status = 'IN_PROGRESS';


