extends layout

block content
  main
    .dashboard-wrapper
      .dashboard-header
        div
          span.dashboard-badge // REPAIR SYSTEM //
          h1.dashboard-title Reparación ##{repair.id_repair}
        a.btn-outline(href="/repairs") 

      .row.mb-4
        .col-md-6.mb-3
          .dashboard-section
            .section-header
              h2.section-title
                span.section-icon 🚗
                | Información del Vehículo
            .p-4
              table.repair-table
                tbody
                  tr
                    td.td-id Marca
                    td= repair.Car.brand
                  tr
                    td.td-id Modelo
                    td= repair.Car.model
                  tr
                    td.td-id Matrícula
                    td
                      span.td-plate= repair.Car.plate

        .col-md-6.mb-3
          .dashboard-section
            .section-header
              h2.section-title
                span.section-icon 👤
                | Cliente
            .p-4
              table.repair-table
                tbody
                  tr
                    td.td-id Nombre
                    td= `${repair.Car.User.name} ${repair.Car.User.surname}`

      .dashboard-section.mb-4
        .section-header
          h2.section-title
            span.section-icon ⚙️
            | Estado de la Reparación
        .p-4
          - var statusClass = repair.status === 'COMPLETED' ? 'status-badge status-completed' : (repair.status === 'IN_PROGRESS' ? 'status-badge status-progress' : 'status-badge status-active')
          span(class=statusClass)= repair.status
          p.mt-3
            span.td-id Diagnóstico: &nbsp;
            span.text-muted= repair.diagnosis

      .dashboard-section
        .section-header
          h2.section-title
            span.section-icon 🔧
            | Tareas Asociadas
        if repair.Tasks && repair.Tasks.length > 0
          .table-wrapper
            table.repair-table
              thead
                tr
                  th Tarea
              tbody
                each task in repair.Tasks
                  tr
                    td= task.name
        else
          .empty-state
            p.empty-text No hay tareas registradas para esta reparación todavía.