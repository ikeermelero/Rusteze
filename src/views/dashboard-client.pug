extends layout

block content
  .clients-wrapper

    .clients-header
      .clients-header-left
        span.clients-badge // TALLER — CLIENTES
        h1.clients-title 👥 Clientes del taller
      if data.totalClientes > 0
        .clients-count
          span= data.totalClientes
          | &nbsp;clientes registrados

    if data.totalClientes === 0
      .clients-empty
        p.empty-text No hay clientes registrados en este taller.

    else
      .clients-section
        .clients-section-header
          h2.clients-section-title Listado de clientes

        .clients-table-wrapper
          table.clients-table
            thead
              tr
                th ID
                th Nombre
                th Apellido
                th Email
                th Acciones
            tbody
              each cliente in data.clientes
                tr
                  td.td-client-id= cliente.id_user
                  td.td-client-name= cliente.name
                  td.td-client-surname= cliente.surname
                  td.td-client-email= cliente.email
                  td
                    a.btn-detail(href=`/client/${cliente.id_user}`) Ver detalles