extends layout

block content
  .container.py-5
    .row.justify-content-center.g-4

      //- LOGIN
      .col-md-6.col-lg-5
        .card.shadow-sm.border-0.rounded-4
          .card-body.p-4
            h2.text-center.mb-4 Iniciar Sesión

            if error
              .alert.alert-danger(role="alert")= error

            form(action="/login" method="POST")
              .mb-3
                label.form-label(for="email") Email
                input#email.form-control(
                  type="email"
                  name="email"
                  placeholder="Correo electrónico"
                  required
                )
              .mb-3
                label.form-label(for="password") Contraseña
                input#password.form-control(
                  type="password"
                  name="password"
                  placeholder="Contraseña"
                  required
                )
              .d-grid
                button.btn.btn-primary(type="submit") Entrar

      //- REGISTRO
      .col-md-6.col-lg-7
        .card.shadow-sm.border-0.rounded-4
          .card-body.p-4
            h2.text-center.mb-4 Registro de Usuario

            form(action="/register" method="POST")
              .row
                .col-md-6.mb-3
                  label.form-label(for="name") Nombre
                  input#name.form-control(
                    type="text"
                    name="name"
                    required
                  )
                .col-md-6.mb-3
                  label.form-label(for="registerEmail") Email
                  input#registerEmail.form-control(
                    type="email"
                    name="email"
                    required
                  )
                .col-md-6.mb-3
                  label.form-label(for="phone") Teléfono (opcional)
                  input#phone.form-control(
                    type="text"
                    name="phone"
                  )
                .col-md-6.mb-3
                  label.form-label(for="dateOfBirth") Fecha de nacimiento
                  input#dateOfBirth.form-control(
                    type="date"
                    name="dateOfBirth"
                  )
                .col-md-6.mb-3
                  label.form-label(for="registerPassword") Contraseña
                  input#registerPassword.form-control(
                    type="password"
                    name="password"
                    required
                  )
                .col-md-6.mb-3
                  label.form-label(for="passwordRepeat") Repetir Contraseña
                  input#passwordRepeat.form-control(
                    type="password"
                    name="passwordRepeat"
                    required
                  )
              .d-grid.mt-3
                button.btn.btn-success(type="submit") Registrarse