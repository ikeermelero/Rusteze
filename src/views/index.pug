extends layout

block content

  section.landing-hero.pro-version#landing-hero
    

    .video-background
      video(autoplay loop muted playsinline poster="https://images.unsplash.com/photo-1486262715619-67b85e0b08d3?auto=format&fit=crop&q=80&w=1600")
        source(src="https://cdn.pixabay.com/video/2021/08/21/85863-591244464_tiny.mp4" type="video/mp4")
    

    .hud-overlay
      .scan-line
      .grid-pattern

    .hero-overlay.deep-overlay

    .hero-content.v-align
      .container
        .row.justify-content-center
          .col-lg-10.text-center
            

            .animate-item.delay-1
              .badge-racing.pro-badge RUST-EZE PROTOCOL [v4.1]
            
            .animate-item.delay-2
              h1.landing-title.pro-title SISTEMA INTEGRAL DE GESTIÓN MECÁNICA
            
            .animate-item.delay-3
              p.landing-lead.pro-lead Optimización de boxes, telemetría de reparaciones y control de inventario de precisión militar. Tu taller, a velocidad de clasificación.
            

            .animate-item.delay-4
              .hero-actions.pro-actions
                a.btn-premium.pro-btn(href="/auth/login") 
                  span Iniciar Sesión 
                  i.bi.bi-cpu.ms-2
                a.btn-outline.pro-btn-outline(href="/auth/register") 
                  span Registrarse
                  i.bi.bi-arrow-right-short.ms-1


  link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css")

  script.
    document.addEventListener('DOMContentLoaded', () => {
      const hero = document.getElementById('landing-hero');
      
      setTimeout(() => {
        hero.classList.remove('loading');
      }, 100);


      document.addEventListener('mousemove', (e) => {
        const video = hero.querySelector('video');
        const amount = 5; // Movimiento muy sutil
        const x = (e.clientX * amount) / window.innerWidth;
        const y = (e.clientY * amount) / window.innerHeight;
        
        video.style.transform = `translate(${-x}px, ${-y}px) scale(1.05)`; // Scale para cubrir bordes
      });
    });