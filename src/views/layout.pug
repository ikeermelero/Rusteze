doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    //- Google Fonts para un look más Pro
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&display=swap")
    //- Bootstrap 5.3
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css")
    //- Tu CSS Industrial
    link(rel="stylesheet", href="/style.css")
    title #{title} - Rust-eze Workshop

  body
    header.main-navbar
      nav.container.d-flex.justify-content-between.align-items-center
        .nav-logo
          a(href="/")
            span.logo-bold RUST-EZE
            span.logo-light GARAGE
        
        .nav-links.d-none.d-md-flex
          a(href="/") Inicio
          a(href="/servicios") Servicios
          a(href="/auth/login").btn-nav-login ACCESO BOXES

    main
      block content

    footer.main-footer
      .container
        .row.align-items-center
          .col-md-6.text-center.text-md-start
            p &copy; 2026 Rust-eze Medicating Bumper Ointment. Todos los derechos reservados.
          .col-md-6.text-center.text-md-end
            a(href="#") Soporte Técnico
            span.mx-2 |
            a(href="#") Privacidad

    //- Scripts de Bootstrap (opcional para interactividad)
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")