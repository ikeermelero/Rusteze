doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&display=swap")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css")
    link(rel="stylesheet" href="/style.css")
    title #{title} - Rust-eze Workshop

  body
    header.main-navbar
      nav.container.d-flex.justify-content-between.align-items-center
        .nav-logo
          a(href="/")
            span.logo-bold RUST-EZE
            span.logo-light  GARAGE

        .nav-links.d-none.d-md-flex
            a(href="/dashboard").btn-nav-login Dashboard
            a(href="/client").btn-nav-login Clientes
            a(href="/repairs").btn-nav-login Reparaciones
            a(href="/reservations").btn-nav-login Reservas
            a(href="/logout").btn-nav-logout Cerrar Sesión

    main
      block content

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")